# the mod name as displayed in-game
displayName: "EctoTech"

# the internal name of your mod
name: "ectotech"

# your name
author: "DeepWorldStudio"

# the fully qualified main class of the mod
main: "ectotech.EctoTech"

# the mod description as seen in the mod dialog
description: "Explore the new planet Ectorum with new technologies and unique features."

# the mod version
version: 0.1

# the minimum game build required to run this mod
minGameVersion: 154

# this is a java mod
java: true
